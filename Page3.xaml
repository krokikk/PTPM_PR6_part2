<Page x:Class="PTPM_PR4.Page3"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PTPM_PR4"
      xmlns:charts="clr-namespace:System.Windows.Forms.DataVisualization.Charting;assembly=System.Windows.Forms.DataVisualization"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Page3" Background ="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>


        <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="0" HorizontalAlignment="Left">
            <Button Content="Страница 2" Grid.Row="0" Margin="6" Height="50" Width="150" FontSize="17" Click="Button_Click_Page2"/>
        </StackPanel>
        <StackPanel Grid.Row="1" Grid.ColumnSpan="3">
            <Image Source="\Images\f3.png" Width="300" ToolTip="Формула к заданию 3"/>
        </StackPanel>
        <StackPanel Grid.Row="2">
            <TextBlock Text="x:"  Margin="6" FontSize="17" HorizontalAlignment="Right"/>
            <TextBlock Text="xk:"  Margin="6" FontSize="17" HorizontalAlignment="Right"/>
            <TextBlock Text="dx:"  Margin="6" FontSize="17" HorizontalAlignment="Right"/>
            <TextBlock Text="Ответ:"  Margin="6,6,6,76" FontSize="17" HorizontalAlignment="Right" ToolTip="Здесь будет выведен ответ"/>
            <Button Content="Вычислить" FontSize="17"  Height="40" Width="110"  Margin="6" HorizontalAlignment="Right" Click="Button_Click_Result" ToolTip="Нажмите чтобы вычислить"/>
            <Button Content="Очистить" FontSize="17"  Height="40" Width="110"  Margin="6" HorizontalAlignment="Right" Click="Button_Click_Clear" ToolTip="Нажмите чтобы очистить поля"/>
        </StackPanel>
        <StackPanel Grid.Row="2" Grid.Column="1" >
            <TextBox PreviewTextInput="TextBox_PreviewTextInput" Margin="6" FontSize="17" x:Name="TBx" ToolTip="Введите левую границу (начальное значение)"/>
            <TextBox PreviewTextInput="TextBox_PreviewTextInput" Margin="6" FontSize="17" x:Name="TBxk" ToolTip="Введите правую границу (конечное значение)"/>
            <TextBox PreviewTextInput="TextBox_PreviewTextInput" Margin="6" FontSize="17" x:Name="TBdx" ToolTip="Введите шаг"/>
            <TextBlock Margin="6" FontSize="13" x:Name="TBres" TextWrapping="Wrap" ToolTip="Здесь будет выведен ответ"/>
        </StackPanel>
        <WindowsFormsHost Grid.Column="2" HorizontalAlignment="Left" Height="240" Margin="10,10,0,0" Grid.Row="2" VerticalAlignment="Top" Width="349" x:Name="ChartHost" ToolTip="График функции">
            <charts:Chart x:Name="Chart">
                <charts:Chart.Legends>
                    <charts:Legend>
                        
                    </charts:Legend>
                </charts:Chart.Legends>
            </charts:Chart>
        </WindowsFormsHost>
    </Grid>

</Page>
