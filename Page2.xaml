<Page x:Class="PTPM_PR4.Page2"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PTPM_PR4"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Page2" Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="0" HorizontalAlignment="Left">
            <Button Content="Страница 1" Grid.Row="0" Margin="6" Height="50" Width="150" FontSize="17" Click="Button_Click_Page1" ToolTip="Нажмите для перехода на предыдущую страницу"/>
        </StackPanel>
        <StackPanel  Orientation="Horizontal" Grid.Row="0" Grid.Column="3" HorizontalAlignment="Right">
            <Button Content="Страница 3" Grid.Row="0" Margin="6" Height="50" Width="150" FontSize="17" Click="Button_Click_Page3" ToolTip="Нажмите для перехода на следующую страницу"/>
        </StackPanel>
        <StackPanel Grid.Row="1" Grid.ColumnSpan="3">
            <Image Source="\Images\f2.png" Width="300" ToolTip="Формула к заданию 2"/>
        </StackPanel>
        <StackPanel Grid.Row="2">
            <TextBlock Text="x:"  Margin="6" FontSize="17" HorizontalAlignment="Right"/>
            <TextBlock Text="i:"  Margin="6" FontSize="17" HorizontalAlignment="Right"/>
            <TextBlock Text="F(x):" Margin="6" FontSize="17" HorizontalAlignment="Right" ToolTip="Выберите значение функции"/>
            <TextBlock Text="Ответ:"  Margin="6,68,6,6" FontSize="17" HorizontalAlignment="Right" ToolTip="Здесь будет выведен ответ"/>
        </StackPanel>
        <StackPanel Grid.Row="2" Grid.Column="1" >
            <TextBox PreviewTextInput="TextBox_PreviewTextInput" Margin="6" FontSize="17" x:Name="TBx" ToolTip="Введите значение x"/>
            <TextBox PreviewTextInput="TextBox_PreviewTextInput" Margin="6" FontSize="17" x:Name="TBi" ToolTip="Введите значение i"/>
            <RadioButton Content="sh(x)" GroupName="func" Margin="6" FontSize="15" Checked="FunCheck" x:Name="rb1" ToolTip="Функция гиперболического синуса"/>
            <RadioButton Content="x^2"  GroupName="func" Margin="6" FontSize="15" Checked="FunCheck" x:Name="rb2" ToolTip="Функция х в квадрате"/>
            <RadioButton Content="e^x"  GroupName="func" Margin="6" FontSize="15" Checked="FunCheck" x:Name="rb3" ToolTip="Функция экспонента в степени х"/>
            <TextBlock Margin="6" FontSize="17" x:Name="TBres" ToolTip="Здесь будет выведен ответ"/>
        </StackPanel>
        <StackPanel Grid.Row="2" Grid.Column="2" >
            <Button Content="Вычислить" FontSize="17"  Height="40" Width="130"  Margin="6" HorizontalAlignment="Left" Click="Button_Click_Result" x:Name="Btn1" ToolTip="Нажмите чтобы вычислить"/>
            <Button Content="Очистить" FontSize="17"  Height="40" Width="130"  Margin="6" HorizontalAlignment="Left" Click="Button_Click_Clear" ToolTip="Нажмите чтобы очистить поля"/>
        </StackPanel>
    </Grid>
</Page>
